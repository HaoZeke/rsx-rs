/target
/radsex-core/target
/radsex-cli/target
*.swp
*.swo
*~
.DS_Store

# pixi
.pixi/
pixi.lock

# Build artifacts
/radsex-core/include/rsx.h

# Generated documentation
# orgmode/ (in docs/orgmode/) is the source of truth.
# docs/export.el (run via `pixi run -e docs mkrst`) exports .org -> .rst into docs/source/.
# Only the following under docs/source/ are hand-maintained:
#   - conf.py
#   - _static/
#   - _templates/
#
# Everything else under docs/source/ is a build artifact and must stay out of git.
/docs/build/
/docs/_build/
/docs/source/**

# Re-include the manual parts of docs/source/
!/docs/source/conf.py
!/docs/source/_static/
!/docs/source/_static/**
!/docs/source/_templates/
!/docs/source/_templates/**

# Generated Rust API documentation
# Produced by sphinx-rustdocgen + sphinxcontrib_rust (see setup-rustdocgen + gen-rust-api tasks
# in pixi.toml and rust_crates + rust_doc_dir in docs/source/conf.py).
# Generated to api/rust/rsx_core/ at repo root. The .. rust:crate::rsx_core directive in the
# reference page uses this to render the API docs. Do not commit the generated tree.
/docs/source/reference/rust-api/rsx_core/

# IDE
.vscode/
.idea/

# ASV
.asv/

# Benchmark intermediate outputs (keep data/ and results/ in git)
benchmarks/data/*/cpp_*.tsv
benchmarks/data/*/rust_*.tsv
benchmarks/data/*/*.amb
benchmarks/data/*/*.ann
benchmarks/data/*/*.bwt
benchmarks/data/*/*.pac
benchmarks/data/*/*.sa
benchmarks/data-regenerated/
benchmarks/literature-workdir/
repro/benchmarks/figshare_package/

# Local project context
.project-ctx.toml
*.so
*.dylib
*.pyd
